<launch>
  <rosparam command="load" file="$(find kalman_localization)/config/ekf_odom_imu_gps.yaml"/>
  <node pkg="robot_localization" type="ekf_localization_node" name="ekf_odom_imu_gps"
        clear_params="true" output="screen">
    <remap from="odometry/filtered" to="/odometry/filtered"/>
  </node>
</launch>
